# GovCareer Auth Service - Environment Variables

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/govcareer_auth
DB_USER=govcareer_admin
DB_PASSWORD=secure_password_123
DB_POOL_MAX=20
DB_POOL_MIN=5

# JWT Configuration (Must be a 256-bit Base64-encoded secret in production)
JWT_SECRET=NDEyM0FBNUJCMkM0RkU1RDY4Nzc5QTIzNEI5QzZFMzVBRjk4QzE2MjkzRTU2RDI0NTVCNzA5RDRC

# Mail Configuration (SMTP)
# Use a provider like SendGrid, Mailgun, or AWS SES in production.
# For local testing, you can use MailHog (localhost:1025)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_AUTH=false
MAIL_STARTTLS=false

# Rate Limiting
# Note: Handled by Bucket4j in-memory (20 req/min per IP)
